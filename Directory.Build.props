<Project>

  <!-- ================================================================
       Ortak Temel Ayarlar (Tüm Projeler İçin)
       Bu dosya: MSBuild tarafından OTOMATIK yüklenir.
       Kapsam: Bu klasörün altındaki TÜM .csproj dosyaları.
       ================================================================ -->

  <PropertyGroup Label="Language &amp; Common Settings">
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <PropertyGroup Label="Code Quality">
    <!-- Warning'leri error olarak say — disiplinli kod için şart -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Bazı nuisance warning'leri error olmaktan çıkar -->
    <WarningsNotAsErrors>NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <!-- .NET SDK analyzers — kod kalitesi önerileri -->
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <!-- IDE0005 ve diğer code-style analyzer'larının build sırasında çalışabilmesi için gerekli.
         XML doc generate ediyoruz ama eksik doc warning'lerini (CS1591) NoWarn'a aldık. -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- NoWarn:
         CS1591 - missing XML doc on public member (we document selectively, not for every member)
         CA1716 - identifier matches VB keyword ('Error' is industry convention in Result pattern) -->
    <NoWarn>$(NoWarn);CS1591;CA1716</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Build Output">
    <!-- Deterministic build — aynı kaynak kod = aynı binary (CI için ideal) -->
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true' OR '$(TF_BUILD)' == 'true'">true</ContinuousIntegrationBuild>
    <!-- Debug sembolleri binary'e göm (deploy kolaylığı) -->
    <DebugType>embedded</DebugType>
    <!-- Implicit namespace import sistemini aç -->
    <InvariantGlobalization>false</InvariantGlobalization>
  </PropertyGroup>

  <PropertyGroup Label="Project Metadata">
    <Company>Fodex</Company>
    <Product>Fodex - Field Operations and Distribution Exchange</Product>
    <Copyright>Copyright © $([System.DateTime]::UtcNow.Year) Fodex</Copyright>
    <NeutralLanguage>en-US</NeutralLanguage>
  </PropertyGroup>

  <PropertyGroup Label="Repository Info">
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/lvin88/Fodex</RepositoryUrl>
  </PropertyGroup>

  <PropertyGroup Label="NuGet Central Package Management">
    <!-- Directory.Packages.props ile merkezi paket yönetimi açık -->
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
  </PropertyGroup>

</Project>
